# ⚠️ PRODUCTION CONFIGURATION EXAMPLE
# Скопируй в .env.production и заполни реальные значения

# --- OKX DEMO (тестовая торговля)
OKX_API_KEY = "your-demo-api-key-here"
OKX_API_SECRET = "your-demo-api-secret-here"
OKX_PASSPHRASE = "your-demo-passphrase-here"
OKX_FLAG = "1"  # 1 = demo, 0 = live

# --- OKX LIVE (реальная торговля) - используй переменные окружения системы!
# НЕ хранить live ключи в .env файле!
# Вместо этого использовать:
# export OKX_LIVE_API_KEY="..."
# export OKX_LIVE_API_SECRET="..."
OKX_LIVE_API_KEY = ""
OKX_LIVE_API_SECRET = ""
OKX_LIVE_PASSPHRASE = ""
OKX_LIVE_FLAG = "1"  # Использовать demo режим для безопасности

# Активный режим
TRADING_MODE = "demo"

# --- PostgreSQL (production БД)
DB_NAME = "cripto_prod"
DB_USER = "cripto"
DB_PASSWORD = "your-strong-password-here"  # ОБЯЗАТЕЛЬНО установить!
DB_HOST = "your-db-server.com"  # или IP
DB_PORT = "5432"

# --- Django settings
DJANGO_SECRET_KEY = "your-very-long-random-secret-key-with-50-plus-characters"
DJANGO_DEBUG = "False"  # КРИТИЧНО: False в production!
DJANGO_ALLOWED_HOSTS = "example.com,www.example.com,your-ip"

# --- Security
SECURE_SSL_REDIRECT = "True"
SESSION_COOKIE_SECURE = "True"
CSRF_COOKIE_SECURE = "True"
SECURE_HSTS_SECONDS = "31536000"

# --- Логирование
LOG_LEVEL = "INFO"
LOG_FILE = "/var/log/cripto/app.log"

# --- Сервер
SERVER_NAME = "your-server-name"
ADMIN_EMAIL = "admin@example.com"
