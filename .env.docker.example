# 🐳 Docker Production Configuration
# Скопируй в .env и заполни реальные значения

# ⚠️ КРИТИЧНО - МЕНЯТЬ ОБЯЗАТЕЛЬНО
DJANGO_SECRET_KEY="сгенерировать с помощью: python -c \"from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())\""
DJANGO_ALLOWED_HOSTS="example.com,www.example.com"
DB_PASSWORD="very-strong-password-here-min-15-chars"

# OKX Demo (безопасно для Docker)
OKX_API_KEY="your-demo-api-key"
OKX_API_SECRET="your-demo-api-secret"
OKX_PASSPHRASE="your-demo-passphrase"
OKX_FLAG="1"

# OKX Live (используй только если уверен!)
# ⚠️ НЕ рекомендуется в Docker
OKX_LIVE_API_KEY=""
OKX_LIVE_API_SECRET=""
OKX_LIVE_PASSPHRASE=""
OKX_LIVE_FLAG="1"

# Режим торговли
TRADING_MODE="demo"
