# Docker configuration for Cripto
# Copy to .env.docker and fill in your values

# Django
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# Database (uses local PostgreSQL on host)
DB_PASSWORD=your-db-password-here

# OKX Demo (Testing)
OKX_API_KEY=your-demo-api-key
OKX_API_SECRET=your-demo-api-secret
OKX_PASSPHRASE=your-demo-passphrase

# OKX Live (Real trading - use with caution!)
OKX_LIVE_API_KEY=
OKX_LIVE_API_SECRET=
OKX_LIVE_PASSPHRASE=

# Trading mode
TRADING_MODE=demo
