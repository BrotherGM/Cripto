# Скопируйте в .env и заполните значения:  cp .env.example .env

# --- OKX ДЕМО (тестовая торговля) ---
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=
OKX_FLAG=1
OKX_DEBUG=false

# --- OKX РЕАЛ (боевая торговля) ---
# Пока можно оставить пустыми/равными демо. Для реальной торговли вписать
# боевые ключи и OKX_LIVE_FLAG=0.
OKX_LIVE_API_KEY=
OKX_LIVE_API_SECRET=
OKX_LIVE_PASSPHRASE=
OKX_LIVE_FLAG=0

# Активный режим торговли: demo (тест) или live (реал).
TRADING_MODE=demo

# --- PostgreSQL (установлен на сервере, ВНЕ Docker) ---
# Контейнер запускается в сети хоста (network_mode: host), поэтому Postgres
# доступен по localhost — как для обычного приложения на сервере.
# Укажите реальные имя БД / пользователя / пароль вашего серверного Postgres.
DB_NAME=Cripto
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*
# Для входа в админку по домену/HTTPS укажите, напр.: https://cripto.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- Автосоздание суперпользователя при старте контейнера (опционально) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=admin12345
DJANGO_SUPERUSER_EMAIL=admin@example.com
